# Bridge identity (required)
SIGNAL_NUMBER=+15555550123

# Remote access (optional — blank = LAN-only). See docs/REMOTE_ACCESS.md
# Shared bearer token protecting the bridge AND the signal-api auth proxy.
SB_AUTH_TOKEN=

# Only if you expose via the bundled Cloudflare tunnel service:
# Auth-proxy host port (default 5001; change if taken)
API_AUTH_PORT=5001

CF_TUNNEL_TOKEN=
